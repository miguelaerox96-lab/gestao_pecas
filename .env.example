# ============================================================
# AutoParts Management — Variáveis de Ambiente
# ============================================================
# Copiar este ficheiro para .env e preencher os valores reais
# NUNCA commitar o ficheiro .env para o repositório Git
# ============================================================

# --- SEGURANÇA (OBRIGATÓRIO EM PRODUÇÃO) ---
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=SUBSTITUIR_POR_CHAVE_FORTE_DE_64_CARACTERES_HEX

# Password do utilizador admin criado automaticamente no 1º arranque
ADMIN_DEFAULT_PASSWORD=SUBSTITUIR_POR_PASSWORD_FORTE

# --- BASE DE DADOS ---
# SQLite local (padrão)
DATABASE_URL=sqlite:///./storage/autoparts.db
# PostgreSQL (descomente e configure se usar PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/autoparts

# --- CORS ---
# Em desenvolvimento use *. Em produção/site, coloque o seu domínio.
# Ex para Cloudflare Tunnel: ALLOWED_ORIGINS=http://localhost:8000,https://admin.teudominio.com
ALLOWED_ORIGINS=*

# --- RATE LIMITING (pedidos de contacto) ---
# Máximo de pedidos de contacto por IP por minuto
INQUIRY_RATE_LIMIT=5
